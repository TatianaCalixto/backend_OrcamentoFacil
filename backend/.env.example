# OrçaFácil — Backend / Exemplo de variáveis de ambiente (S22-T01).
# Copie para `.env` e ajuste. O `.env` real é gitignored — NUNCA commite segredos.
# Em produção, configure estas variáveis no painel de secrets do provedor (Render/
# Railway), não em arquivo.

# --- Banco de dados (OBRIGATÓRIO) ---
# Postgres gerenciado (Supabase / Neon / Render Postgres). Driver psycopg.
# Ex. Supabase: postgresql+psycopg://postgres:SENHA@db.PROJ.supabase.co:5432/postgres
DATABASE_URL=postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME

# --- JWT (OBRIGATÓRIO) ---
# Gere um segredo longo e aleatório (ex.: `python -c "import secrets;print(secrets.token_urlsafe(48))"`).
JWT_SECRET=troque-por-uma-string-aleatoria-longa
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_MINUTES=10080

# --- Ambiente ---
# development | test | staging | production. Em production o logging vira JSON e
# o HSTS é enviado nas respostas.
ENVIRONMENT=production

# --- CORS: origens permitidas (CSV "a,b" ou JSON '["a","b"]') ---
CORS_ORIGINS=https://meu-painel.streamlit.app,https://meu-front.app

# --- Log shipping externo (OPCIONAL, S21-T03) ---
# Se AMBOS definidos, logs estruturados são enviados ao agregador (Better Stack/
# Logtail/etc.). Ausentes -> apenas stdout (comportamento padrão).
# LOG_SHIPPING_URL=https://in.logs.betterstack.com
# LOG_SHIPPING_TOKEN=seu-token-de-ingestao
